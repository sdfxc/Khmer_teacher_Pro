{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "Represent a teacher account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "schoolName": { "type": "string" },
        "subjects": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "schoolName", "username", "password"]
    },
    "Class": {
      "title": "Class",
      "description": "Represent a classroom created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pickedIds": { "type": "array" },
        "cards": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Student": {
      "title": "Student",
      "description": "Represent a student inside a class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "number" },
        "emoji": { "type": "string" },
        "gender": { "type": "string", "enum": ["ប្រុស", "ស្រី"] },
        "status": { "type": "string", "enum": ["ឆ្នើម", "សកម្ម", "កំពុងរីកចម្រើន", "គួរឲ្យបារម្ភ"] },
        "classId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "score"]
    }
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Collection of teachers."
    },
    "/teachers/{teacherId}/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes belonging to a teacher."
    },
    "/teachers/{teacherId}/classes/{classId}/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students inside a class."
    }
  }
}
