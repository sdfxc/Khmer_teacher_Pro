rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitive definition helpers
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Validation helper for Teacher
    function isValidTeacher(data) {
      return data.keys().hasAll(['id', 'name', 'schoolName', 'username', 'password'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.schoolName is string && data.schoolName.size() <= 150
        && data.username is string && data.username.size() <= 50
        && data.password is string && data.password.size() <= 100;
    }
    
    // Validation helper for Class
    function isValidClass(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100;
    }
    
    // Validation helper for Student
    function isValidStudent(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.score is number;
    }

    match /active_pins/{pin} {
      allow get, create, update, delete: if isValidId(pin);
      allow list: if false;
    }

    match /teachers/{teacherId} {
      allow get: if isValidId(teacherId);
      allow create: if isValidId(teacherId) && isValidTeacher(incoming());
      allow update: if isValidId(teacherId) && isValidTeacher(incoming()) && existing().password == incoming().password;
      allow delete: if isValidId(teacherId) && existing() != null;
      
      match /classes/{classId} {
        allow get: if isValidId(teacherId) && isValidId(classId);
        allow list: if isValidId(teacherId);
        allow create, update: if isValidId(teacherId) && isValidId(classId) 
          && (teacherId == 'local' || exists(/databases/$(database)/documents/teachers/$(teacherId)));
        allow delete: if isValidId(teacherId) && isValidId(classId);
        
        match /groupsData/{docId} {
          allow get: if isValidId(teacherId) && isValidId(classId) && isValidId(docId);
          allow list: if isValidId(teacherId) && isValidId(classId);
          allow create, update: if isValidId(teacherId) && isValidId(classId) && isValidId(docId);
          allow delete: if isValidId(teacherId) && isValidId(classId) && isValidId(docId);
        }
      }
      
      match /classes/{classId}/students/{studentId} {
        allow get: if isValidId(teacherId) && isValidId(classId) && isValidId(studentId);
        allow list: if isValidId(teacherId) && isValidId(classId);
        allow create, update: if isValidId(teacherId) && isValidId(classId) && isValidId(studentId)
          && (teacherId == 'local' || isValidStudent(incoming()));
        allow delete: if isValidId(teacherId) && isValidId(classId) && isValidId(studentId);
      }
    }
  }
}
